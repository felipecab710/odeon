# Odeon API environment variables
# Copy to .env and fill in your values

# RunPod ML server (GPU inference)
# Get this from RunPod pod → TCP Port Mappings → port 8002 proxy URL
RUNPOD_URL=https://YOUR-POD-ID-8002.proxy.runpod.net

# Optional bearer token if you set ODEON_ML_API_KEY on the RunPod server
RUNPOD_API_KEY=
