{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Odeon",
  "version": "0.1.0",
  "identifier": "com.odeon.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Odeon",
        "width": 1600,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 700,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "backgroundColor": "#1A1A1A",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/odeon-engine"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
